# ══════════════════════════════════════════════════════════════════
#  docs — 部署密钥模板
#  cp .env.secrets.example .env.secrets 并填写真实值（不要提交 .env.secrets）
# ══════════════════════════════════════════════════════════════════

# JWT 签名密钥，生成方式：openssl rand -base64 48
ADMIN_JWT_SECRET=

# Cloudflare Turnstile secret key（Dashboard 创建 Widget 后获得）
TURNSTILE_SECRET=

# GitHub Fine-grained PAT：对 account/relay/analytics/docs 四个仓库
# 开启 Contents: Read and write 权限，供在线编辑器保存文档使用（可选，
# 不填则站点正常访问，仅在线编辑器的读取/保存功能不可用）
GITHUB_TOKEN=

# 初始管理员密码（仅用于本地生成 hash 并写入 D1，不会以明文存到线上）
ADMIN_PASSWORD=
